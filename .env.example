# ── App ─────────────────────────────────────────────────────────────
# Base URL of the app (no trailing slash). Use your Vercel URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────────────
# Create a project at https://supabase.com/dashboard, then:
# Project Settings → API → copy Project URL + anon key + service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Server-only. NEVER expose this to the browser. Used by the Stripe
# webhook handler to update billing state (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Stripe (test mode) ──────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Created by `stripe listen` locally, or from the webhook endpoint page in prod.
STRIPE_WEBHOOK_SECRET=whsec_...
# Create two recurring Products/Prices in the Stripe test dashboard
# (e.g. Pro $149/mo, Scale $399/mo) and paste the price IDs here.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# ── Anthropic (AI answer generation) ────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model used for drafting answers.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: semantic retrieval (pgvector + Voyage AI embeddings) ---
# Leave unset to use the built-in lexical retrieval. To enable:
#   1. Run supabase/migrations/0002_pgvector.sql in the Supabase SQL editor
#   2. Create a key at https://dashboard.voyageai.com and set it here
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3.5-lite
